---
const navLinks = [
  { href: '/', label: 'TOP' },
  { href: '/works', label: 'WORKS' },
  { href: '/profile', label: 'PROFILE' },
  { href: '/contact', label: 'CONTACT' },
];
const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-ink/[0.05]"
>
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a
      href="/"
      class="font-bold text-sm tracking-[0.2em] text-ink hover:text-accent transition-colors duration-200"
    >
      MAKOTO TAMURA
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-10">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`text-xs tracking-widest font-medium transition-colors duration-200 ${
            currentPath === link.href ||
            (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-accent'
              : 'text-ink-mid hover:text-ink'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile toggle -->
    <button
      id="mobile-nav-toggle"
      class="md:hidden text-ink-mid hover:text-ink transition-colors"
      aria-label="メニューを開く"
      aria-expanded="false"
    >
      <svg
        id="icon-open"
        width="22"
        height="22"
        viewBox="0 0 22 22"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
      >
        <line x1="2" y1="6" x2="20" y2="6" />
        <line x1="2" y1="11" x2="20" y2="11" />
        <line x1="2" y1="16" x2="20" y2="16" />
      </svg>
      <svg
        id="icon-close"
        width="22"
        height="22"
        viewBox="0 0 22 22"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        class="hidden"
      >
        <line x1="4" y1="4" x2="18" y2="18" />
        <line x1="18" y1="4" x2="4" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-nav" class="hidden md:hidden bg-cream border-t border-seam">
    <nav class="max-w-6xl mx-auto px-6 py-6 flex flex-col gap-5">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`text-sm tracking-widest font-medium ${
            currentPath === link.href ? 'text-accent' : 'text-ink-mid'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('mobile-nav-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  function updateHeader() {
    if (window.scrollY > 40) {
      header?.classList.add('header-scrolled');
    } else {
      header?.classList.remove('header-scrolled');
    }
  }
  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  toggle?.addEventListener('click', () => {
    const isOpen = !mobileNav?.classList.contains('hidden');
    mobileNav?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
